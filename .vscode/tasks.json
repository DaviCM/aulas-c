{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Create bin subdirectory",
            "detail": "Create current subdirectory inside ./bin. Necessary for VS not to freak out",
            "linux": {
                "command": "/bin/mkdir",
                "args": [
                    "-p",
                    "./bin/${relativeFileDirname}"
                ]
            },
            "windows": {
                "command": "New-Item",
                "args": [
                    "-ItemType",
                    "Directory",
                    "-Force",
                    "-Path",
                    "./bin/${relativeFileDirname}"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
		        "reveal": "silent",
		        "close": true
            }
        },
        {
            "type": "shell",
            "label": "C/C++: gcc build active file",
            "detail": "Task generated by Debugger.",
            "linux": {
                "command": "/usr/bin/gcc",
                "args": [
                    "-fdiagnostics-color=always",
                    "-Wall",
                    "-Wextra",
                    "-std=c23",
                    "-pedantic",
                    "-g",
                    "${file}",
                    "-o",
                    "${workspaceFolder}/bin/${relativeFileDirname}/${fileBasenameNoExtension}"
                ]
            },
            "windows": {
                "command": "C:/msys64/ucrt64/bin/gcc.exe",
                "args": [
                    "-fdiagnostics-color=always",
                    "-Wall",
                    "-Wextra",
                    "-std=c23",
                    "-pedantic",
                    "-g",
                    "${file}",
                    "-o",
                    "${workspaceFolder}/bin/${relativeFileDirname}/${fileBasenameNoExtension}.exe"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
        },
        {
            "label": "Run all",
            "dependsOn": [
                "Create bin subdirectory",
                "C/C++: gcc build active file"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}